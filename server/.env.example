# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=qingjia_db
DB_USER=qingjia_app
DB_PASSWORD=replace-with-app-db-password

# JWT 配置
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# 服务配置
PORT=3000
NODE_ENV=development
APP_VERSION=1.0.0
TRUST_PROXY_HOPS=0

# Docker 局域网演示可改成 http://电脑IP:8090,http://电脑IP:8091,https://电脑IP:8443
ALLOWED_ORIGINS=http://localhost:8090,http://localhost:8091,http://127.0.0.1:8090,http://127.0.0.1:8091,http://192.168.1.100:8090,http://192.168.1.100:8091,https://192.168.1.100:8443

# JPush
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=
