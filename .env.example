MYSQL_ROOT_PASSWORD=replace-with-root-password
MYSQL_DATABASE=qingjia_db
MYSQL_EXPOSE_BIND=127.0.0.1
MYSQL_EXPOSE_PORT=3306

DB_USER=qingjia_app
DB_PASSWORD=replace-with-app-db-password

BACKUP_DB_USER=qingjia_backup
BACKUP_DB_PASSWORD=replace-with-backup-db-password

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

NODE_ENV=production
APP_VERSION=1.0.0
TRUST_PROXY_HOPS=1
ALLOWED_ORIGINS=http://localhost:8090,http://localhost:8091,http://127.0.0.1:8090,http://127.0.0.1:8091,http://192.168.1.100:8090,http://192.168.1.100:8091,https://192.168.1.100:8443

SERVER_EXPOSE_PORT=3000
SERVER_EXPOSE_BIND=127.0.0.1
NGINX_STUDENT_PORT=8090
NGINX_TEACHER_PORT=8091
